pipeline {
    agent any

    stages {
        stage('Checkout GIT') {
            steps {
                echo 'Pulling ...'
                git(
                    branch: 'RimOuertani-5SAE7-G5',
                    url: 'https://github.com/SghaierAya1/5SAE7-G5-Kaddem.git'
                )
            }
        }

        stage('MVN CLEAN') {
            steps {
                echo "Running Maven Clean..."
                dir('kaddem') { // On se déplace dans le dossier 'kaddem' où se trouve le fichier pom.xml
                    sh 'mvn clean'
                }
            }
        }

        stage('MVN COMPILE') {
            steps {
                echo "Running Maven Compile..."
                dir('kaddem') { // Toujours dans le dossier 'kaddem'
                    sh 'mvn compile'
                }
            }
        }

        stage('Static Analysis') {
                    steps {
                        dir('kaddem') {
                            echo "Running SonarQube analysis..."
                            sh '''
                            mvn sonar:sonar \
                            -Dsonar.projectKey=kaddem \
                            -Dsonar.host.url=http://192.168.33.10:9000 \
                            -Dsonar.login=admin \
                            -Dsonar.password=Rim12356113*
                            '''
                        }
                    }
                }
            }
}
