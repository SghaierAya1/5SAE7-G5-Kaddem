pipeline {
    agent any

    stages {
        // Stage 1: Clone Repository
        stage('Clone Repository') {
            steps {
                echo "Cloning repository from GitHub..."
                // Jenkins gère le clonage en fonction de la configuration du job.
            }
        }

        // Stage 2: Build the Project
        stage('Build') {
            steps {
                script {
                    echo "Building the project with Maven..."
                    dir('kaddem') {  // Navigue dans le répertoire contenant le fichier pom.xml
                        sh 'mvn clean install'  // Compile le projet
                    }
                }
            }
        }

        // Stage 3: SonarQube Analysis
        stage('Sonarqube') {
            steps {
                script {
                    echo "Running SonarQube analysis..."
                    dir('kaddem') {  // Navigue dans le répertoire contenant le fichier pom.xml
                        sh 'mvn sonar:sonar -Dsonar.login=admin -Dsonar.password=Rim12356113* -Dmaven.test.skip=true'  // Exécute l'analyse SonarQube
                    }
                }
            }
        }
    }

    post {
        always {
            echo 'Pipeline execution completed.'
        }
        success {
            echo 'Build and tests were successful!'
        }
        failure {
            echo 'Build or tests failed. Check the logs for details.'
        }
    }
}
