pipeline {
    agent any  

    stages {
        // Stage 1: Clone Repository
        stage('Clone Repository') {
            steps {
                echo "Cloning repository from GitHub..."
                // This is informational; Jenkins handles cloning based on job config.
            }
        }

        // Stage 2: Build the Project
        stage('Build') {
            steps {
                script {
                    echo "Building the project with Maven..."
                    dir('kaddem') {  // Navigate to the kaddem directory
                        sh 'mvn clean install'  // Build the project
                    }
                }
            }
        }

        // Stage 3: SonarQube Analysis
        stage('Sonarqube') {
            steps {
                echo "Running SonarQube analysis..."
                sh 'mvn sonar:sonar -Dsonar.login=admin -Dsonar.password=Rim12356113* -Dmaven.test.skip=true'
            }
        }
    }

    post {
        always {
            echo 'Pipeline execution completed.'
        }
        success {
            echo 'Build and tests were successful!'
        }
        failure {
            echo 'Build or tests failed. Check the logs for details.'
        }
    }
}
